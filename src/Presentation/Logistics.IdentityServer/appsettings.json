{
  "Serilog": {
    "Using": ["Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Information",
        "Microsoft.AspNetCore.DataProtection": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/identityapp-.log",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Month"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithThreadId", "WithExceptionDetails"]
  },
  "ConnectionStrings": {
    "MasterDatabase": "Host=localhost; Port=5432; Database=master_dispatchload; Username=postgres; Password=Test12345#; Include Error Detail=true",
    "UsTenantDatabase": "Host=localhost; Port=5432; Database=us_dispatchload; Username=postgres; Password=Test12345#; Include Error Detail=true"
  },
  "TenantDatabaseDefaults": {
    "NameTemplate": "{tenant}_dispatchload",
    "Host": "localhost",
    "Port": 5432,
    "UserId": "postgres",
    "Password": "Test12345#"
  },
  "Authentication": {
    "Google": {
      "ClientId": "<Google OAuth Client ID>",
      "ClientSecret": "<Google OAuth Client Secret>"
    }
  },
  "GoogleRecaptcha": {
    "SiteKey": "<Google captcha site key>",
    "SecretKey": "<Google captcha secret key>"
  },
  "Impersonation": {
    "TmsPortalUrl": "http://localhost:7003"
  },
  "Resend": {
    "ApiKey": "<Resend API key>",
    "SenderEmail": "noreply@dispatchload.app",
    "SenderName": "DispatchLoad"
  },
  "IdentityServer": {
    "Clients": [
      {
        "Enabled": true,
        "ClientId": "dispatchload.adminportal",
        "ClientName": "DispatchLoad Admin Portal",
        "RequireClientSecret": false,
        "AllowedGrantTypes": ["authorization_code"],
        "AccessTokenLifetime": 259200,
        "IdentityTokenLifetime": 86400,
        "RedirectUris": ["http://localhost:7002", "https://admin.dispatchload.app"],
        "PostLogoutRedirectUris": ["http://localhost:7002", "https://admin.dispatchload.app"],
        "AllowedCorsOrigins": ["http://localhost:7002", "https://admin.dispatchload.app"],
        "AllowOfflineAccess": true,
        "AllowedScopes": ["openid", "profile", "roles", "tenant", "dispatchload.api.admin"]
      },
      {
        "Enabled": true,
        "ClientId": "dispatchload.tmsportal",
        "ClientName": "DispatchLoad TMS Portal",
        "RequireClientSecret": false,
        "AccessTokenLifetime": 259200,
        "IdentityTokenLifetime": 86400,
        "AllowedGrantTypes": ["authorization_code"],
        "RedirectUris": [
          "http://localhost:7003",
          "https://tms.dispatchload.app",
          "https://my-dispatch-logistics-angular.vercel.app"
        ],
        "PostLogoutRedirectUris": [
          "http://localhost:7003",
          "https://tms.dispatchload.app",
          "https://my-dispatch-logistics-angular.vercel.app"
        ],
        "AllowedCorsOrigins": [
          "http://localhost:7003",
          "https://tms.dispatchload.app",
          "https://my-dispatch-logistics-angular.vercel.app"
        ],
        "AllowOfflineAccess": true,
        "AllowedScopes": ["openid", "profile", "roles", "tenant", "dispatchload.api.tenant"]
      },
      {
        "Enabled": true,
        "ClientId": "dispatchload.customerportal",
        "ClientName": "DispatchLoad Customer Portal",
        "RequireClientSecret": false,
        "AccessTokenLifetime": 259200,
        "IdentityTokenLifetime": 86400,
        "AllowedGrantTypes": ["authorization_code"],
        "RedirectUris": ["http://localhost:7004", "https://customer.dispatchload.app"],
        "PostLogoutRedirectUris": ["http://localhost:7004", "https://customer.dispatchload.app"],
        "AllowedCorsOrigins": ["http://localhost:7004", "https://customer.dispatchload.app"],
        "AllowOfflineAccess": true,
        "AllowedScopes": ["openid", "profile", "roles", "tenant", "dispatchload.api.tenant"]
      },
      {
        "Enabled": true,
        "ClientId": "dispatchload.driverapp",
        "ClientName": "DispatchLoad Driver App",
        "RequireClientSecret": false,
        "AccessTokenLifetime": 259200,
        "IdentityTokenLifetime": 86400,
        "AllowedGrantTypes": ["password", "refresh_token"],
        "AllowOfflineAccess": true,
        "AllowedScopes": [
          "openid",
          "profile",
          "roles",
          "tenant",
          "dispatchload.api.tenant",
          "offline_access"
        ]
      }
    ]
  }
}
